# ========================
# LLM Provider
# Chọn: "groq" hoặc "ollama"
# ========================
LLM_PROVIDER=groq

# Groq (API)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama (Local) — chạy khi nâng RAM
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ========================
# Embedding Provider
# Chọn: "local" hoặc "groq"
# local = sentence-transformers (multilingual, tốt cho tiếng Việt)
# ========================
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=intfloat/multilingual-e5-large

# ========================
# Vector DB
# ========================
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=rag_edu

# ========================
# Database
# ========================
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/rag_edu

# ========================
# Auth
# ========================
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ========================
# App
# ========================
APP_ENV=development
LOG_LEVEL=DEBUG
